generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Gym {
  id                       Int        @id @default(autoincrement())
  name                     String
  razorpay_key_id          String
  razorpay_key_secret      String
  razorpay_webhook_secret  String
  whatsapp_phone_number_id String
  whatsapp_access_token    String     @db.Text
  google_sheet_id          String
  owner_phone              String
  created_at               DateTime   @default(now())
  last_error_message       String?    @db.Text
  last_health_check_at     DateTime?
  onboarding_token         String?
  status                   String     @default("onboarding")
  last_error_at            DateTime?
  razorpay_valid           Boolean?
  sheet_valid              Boolean?
  whatsapp_valid           Boolean?
  subscription_expires_at  DateTime?
  gymOwners                GymOwner[]
  members                  Member[]
  payments                 Payment[]
  renewals                 Renewal[]
  reactivation_campaigns   ReactivationCampaign[]
  leads                    Lead[]
}

model Member {
  id                          Int                      @id @default(autoincrement())
  gym_id                      Int
  name                        String
  phone                       String
  plan_name                   String
  plan_amount                 Float
  join_date                   DateTime
  expiry_date                 DateTime
  status                      String                   @default("active")
  last_reminder_sent_at       DateTime?
  created_at                  DateTime                 @default(now())
  plan_duration_days          Int                      @default(30)
  churned_at                  DateTime?
  reactivation_sent_at        DateTime?
  reactivation_offer_percent  Float?
  gym                         Gym                      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  payments                    Payment[]
  renewals                    Renewal[]
  reactivation_campaigns      ReactivationCampaign[]

  @@unique([gym_id, phone])
}

model Payment {
  id                       Int      @id @default(autoincrement())
  gym_id                   Int
  member_id                Int
  razorpay_payment_link_id String
  amount                   Float
  status                   String   @default("created")
  created_at               DateTime @default(now())
  gym                      Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member                   Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([gym_id], map: "Payment_gym_id_fkey")
  @@index([member_id], map: "Payment_member_id_fkey")
}

model Renewal {
  id                       Int       @id @default(autoincrement())
  gym_id                   Int
  member_id                Int
  amount                   Float
  status                   String    @default("pending")
  razorpay_payment_link_id String?
  razorpay_short_url       String?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  whatsapp_message_id      String?
  whatsapp_sent_at         DateTime?
  whatsapp_status          String?
  retry_count              Int       @default(0)
  last_retry_at            DateTime?
  plan_duration_days       Int       @default(30)
  recovery_step            Int       @default(0)
  discount_percent         Float?
  discounted_amount        Float?
  recovery_completed       Boolean   @default(false)
  gym                      Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member                   Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([gym_id])
  @@index([member_id])
}

model GymOwner {
  id         Int      @id @default(autoincrement())
  gym_id     Int
  name       String
  email      String   @unique
  phone      String
  password   String
  created_at DateTime @default(now())
  gym        Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@index([gym_id], map: "GymOwner_gym_id_fkey")
}

model ReactivationCampaign {
  id               Int       @id @default(autoincrement())
  gym_id           Int
  member_id        Int
  discount_percent Float
  offer_expiry     DateTime
  status           String    @default("sent") // sent | converted | expired
  sent_at          DateTime  @default(now())
  converted_at     DateTime?
  gym              Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member           Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([gym_id])
  @@index([member_id])
}

model Lead {
  id           Int       @id @default(autoincrement())
  gym_id       Int
  name         String
  phone        String
  source       String?   // walk_in | referral | instagram | google
  stage        String    @default("walk_in") // walk_in | trial | converted | lost
  trial_start  DateTime?
  trial_end    DateTime?
  converted_at DateTime?
  lost_reason  String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  gym          Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@unique([gym_id, phone])
  @@index([gym_id])
}
