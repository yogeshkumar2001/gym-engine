generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Gym {
  id                       Int        @id @default(autoincrement())
  name                     String
  razorpay_key_id          String
  razorpay_key_secret      String
  razorpay_webhook_secret  String
  whatsapp_phone_number_id_deprecated String?
  whatsapp_access_token_deprecated    String?   @db.Text
  whatsapp_status                     String    @default("not_setup")
  google_sheet_id          String
  owner_phone              String
  created_at               DateTime   @default(now())
  last_error_message       String?    @db.Text
  last_health_check_at     DateTime?
  onboarding_token         String?
  status                   String     @default("onboarding")
  last_error_at            DateTime?
  razorpay_valid           Boolean?
  sheet_valid              Boolean?
  whatsapp_valid           Boolean?
  subscription_expires_at  DateTime?
  last_synced_at           DateTime?
  last_sync_member_count   Int?
  last_sync_error          String?   @db.Text
  services                      Json      @default("{\"payments\":true,\"invoice\":true,\"whatsapp_reminders\":true,\"whatsapp_summary\":true,\"google_sheet_sync\":true,\"offers\":false}")
  recovery_discount_percent     Float     @default(5)
  reactivation_discount_percent Float     @default(10)
  upi_id                        String?
  subscription_tier             String    @default("starter") // starter | growth | pro | enterprise
  member_limit                  Int       @default(100)
  gymOwners                GymOwner[]
  gymOwnerAccess           GymOwnerGym[]
  members                  Member[]
  payments                 Payment[]
  renewals                 Renewal[]
  reactivation_campaigns   ReactivationCampaign[]
  leads                    Lead[]
  plans                    Plan[]
  attendance               Attendance[]
  whatsapp_account         WhatsappAccount?
  whatsapp_config          WhatsappConfig?
  message_queue            MessageQueue[]
}

model Plan {
  id            Int      @id @default(autoincrement())
  gym_id        Int
  name          String
  duration_days Int
  price         Float
  status        String   @default("active") // active | inactive
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  gym           Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@unique([gym_id, name])
  @@index([gym_id])
}

model Member {
  id                          Int                      @id @default(autoincrement())
  gym_id                      Int
  name                        String
  phone                       String
  plan_name                   String
  plan_amount                 Float
  join_date                   DateTime
  expiry_date                 DateTime
  status                      String                   @default("active")
  last_reminder_sent_at       DateTime?
  created_at                  DateTime                 @default(now())
  plan_duration_days          Int                      @default(30)
  churned_at                  DateTime?
  deleted_at                  DateTime?
  reactivation_sent_at        DateTime?
  reactivation_offer_percent  Float?
  photo_url                   String?
  id_proof_type               String?
  id_proof_number             String?
  id_proof_url                String?
  gym                         Gym                      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  payments                    Payment[]
  renewals                    Renewal[]
  reactivation_campaigns      ReactivationCampaign[]
  attendance                  Attendance[]

  @@unique([gym_id, phone])
  @@index([gym_id, status])
  @@index([gym_id, expiry_date])
}

model Payment {
  id                       Int      @id @default(autoincrement())
  gym_id                   Int
  member_id                Int
  razorpay_payment_link_id String
  amount                   Float
  status                   String   @default("created")
  created_at               DateTime @default(now())
  gym                      Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member                   Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([gym_id], map: "Payment_gym_id_fkey")
  @@index([member_id], map: "Payment_member_id_fkey")
}

model Renewal {
  id                       Int       @id @default(autoincrement())
  gym_id                   Int
  member_id                Int
  amount                   Float
  status                   String    @default("pending")
  razorpay_payment_link_id String?
  razorpay_short_url       String?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  whatsapp_message_id      String?
  whatsapp_sent_at         DateTime?
  whatsapp_status          String?
  retry_count              Int       @default(0)
  last_retry_at            DateTime?
  plan_duration_days       Int       @default(30)
  recovery_step            Int       @default(0)
  discount_percent         Float?
  discounted_amount        Float?
  recovery_completed       Boolean   @default(false)
  payment_method           String?
  upi_url                  String?
  gym                      Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member                   Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([gym_id])
  @@index([gym_id, status])
  @@index([member_id])
}

model GymOwner {
  id         Int      @id @default(autoincrement())
  gym_id     Int
  name       String
  email      String?  @unique
  phone      String   @unique
  password   String
  created_at DateTime @default(now())
  gym        Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  gymAccess  GymOwnerGym[]

  @@index([gym_id], map: "GymOwner_gym_id_fkey")
}

model ReactivationCampaign {
  id               Int       @id @default(autoincrement())
  gym_id           Int
  member_id        Int
  discount_percent Float
  offer_expiry     DateTime
  status           String    @default("sent") // sent | converted | expired
  sent_at          DateTime  @default(now())
  converted_at     DateTime?
  gym              Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member           Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([gym_id])
  @@index([member_id])
}

model GymOwnerGym {
  id         Int      @id @default(autoincrement())
  owner_id   Int
  gym_id     Int
  role       String   @default("owner") // owner | manager | viewer
  created_at DateTime @default(now())
  owner      GymOwner @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  gym        Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@unique([owner_id, gym_id])
  @@index([owner_id])
  @@index([gym_id])
}

model Attendance {
  id             Int       @id @default(autoincrement())
  gym_id         Int
  member_id      Int
  checked_in_at  DateTime  @default(now())
  checked_out_at DateTime?
  gym            Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member         Member    @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([gym_id, checked_in_at])
  @@index([member_id])
}

model Lead {
  id           Int       @id @default(autoincrement())
  gym_id       Int
  name         String
  phone        String
  source       String?   // walk_in | referral | instagram | google
  stage        String    @default("walk_in") // walk_in | trial | converted | lost
  trial_start  DateTime?
  trial_end    DateTime?
  converted_at DateTime?
  lost_reason  String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  gym          Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@unique([gym_id, phone])
  @@index([gym_id])
}

model WhatsappAccount {
  id              String    @id @default(uuid()) @db.Char(36)
  gym_id          Int       @unique
  phone_number_id String?   @db.VarChar(50)
  display_phone   String    @db.VarChar(15)
  waba_id         String?   @db.VarChar(50)
  status          String    @default("pending")  // pending|verifying|active|suspended|deactivated
  verified_at     DateTime?
  quality_rating  String    @default("GREEN")    // GREEN|YELLOW|RED
  messaging_tier  String    @default("TIER_1")   // TIER_1|TIER_2|TIER_3
  fallback_mode   Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  gym             Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@index([gym_id])
  @@index([phone_number_id])
}

model WhatsappTemplate {
  id               String   @id @default(uuid()) @db.Char(36)
  template_name    String   @db.VarChar(100)
  template_type    String   @db.VarChar(30)  // renewal_reminder|recovery_day1|...|daily_summary|payment_confirm
  language         String   @default("en") @db.VarChar(10)
  meta_template_id String?  @db.VarChar(50)
  status           String   @default("draft")  // draft|submitted|approved|rejected|paused|disabled
  rejection_reason String?  @db.Text
  body_text        String   @db.Text
  button_config    Json?
  quality_score    Decimal? @db.Decimal(3, 2)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([template_name, language])
}

model MessageQueue {
  id               String    @id @default(uuid()) @db.Char(36)
  gym_id           Int
  member_id        Int?
  template_type    String    @db.VarChar(30)
  template_params  Json
  recipient_phone  String    @db.VarChar(15)
  status           String    @default("queued")  // queued|sending|sent|delivered|read|failed|dead
  attempts         Int       @default(0)
  max_attempts     Int       @default(3)
  next_retry_at    DateTime?
  wamid            String?   @db.VarChar(100)
  error_code       String?   @db.VarChar(20)
  error_detail     String?   @db.Text
  scheduled_at     DateTime  @default(now())
  sent_at          DateTime?
  delivered_at     DateTime?
  read_at          DateTime?
  failed_at        DateTime?
  trigger_type     String?   @db.VarChar(30)  // expiry_cron|recovery_engine|winback|daily_summary|manual|invoice
  trigger_ref      String?   @db.Char(36)
  created_at       DateTime  @default(now())
  gym              Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@index([status, next_retry_at])
  @@index([gym_id, member_id, created_at])
  @@index([wamid])
}

model WhatsappConfig {
  id                     String   @id @default(uuid()) @db.Char(36)
  gym_id                 Int      @unique
  reminder_days_before   Json     @default("[7, 3, 1]")
  reminder_send_time     String   @default("09:00") @db.VarChar(5)
  summary_send_time      String   @default("20:00") @db.VarChar(5)
  recovery_enabled       Boolean  @default(true)
  recovery_discount_pct  Decimal  @default(5.0) @db.Decimal(4, 1)
  recovery_start_day     Int      @default(1)
  recovery_sequence      Json     @default("[{\"day\":1,\"action\":\"reminder\",\"template\":\"recovery_day1\"},{\"day\":2,\"action\":\"reminder\",\"template\":\"recovery_day2\"},{\"day\":4,\"action\":\"discount\",\"template\":\"recovery_discount\"},{\"day\":6,\"action\":\"final_notice\",\"template\":\"recovery_final\"}]")
  winback_enabled        Boolean  @default(true)
  winback_delay_days     Int      @default(30)
  winback_discount_pct   Decimal  @default(10.0) @db.Decimal(4, 1)
  winback_max_attempts   Int      @default(2)
  payment_mode           String   @default("razorpay") @db.VarChar(20)  // razorpay|upi_only|cash_only|razorpay_upi
  upi_id                 String?  @db.VarChar(100)
  razorpay_enabled       Boolean  @default(false)
  notify_on_payment      Boolean  @default(true)
  notify_on_new_member   Boolean  @default(true)
  daily_summary_enabled  Boolean  @default(true)
  quiet_start            String   @default("21:00") @db.VarChar(5)
  quiet_end              String   @default("08:00") @db.VarChar(5)
  language_pref          String   @default("en") @db.VarChar(10)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
  gym                    Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@index([gym_id])
}

model SystemToken {
  id             String    @id @default(uuid()) @db.Char(36)
  token_type     String    @db.VarChar(30)  // 'waba_system_user'
  access_token   String    @db.Text         // AES-256-GCM encrypted
  expires_at     DateTime
  refresh_token  String?   @db.Text         // AES-256-GCM encrypted
  last_verified  DateTime?
  status         String    @default("active")  // active|expiring_soon|expired|revoked
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
}
